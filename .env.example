# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Cloud — OAuth Client (YouTube Data API v3)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/youtube/callback

# Resend — e-mail transacional
RESEND_API_KEY=

# Segredo compartilhado para o webhook de matrícula (gere um valor forte)
WEBHOOK_SECRET=

# URL pública da app (em produção: https://seu-projeto.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000
